# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key

# AWS Textract
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1

# Stripe
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-publishable-key

# Stripe Product IDs (create in Stripe Dashboard)
STRIPE_PERSONAL_MONTHLY_PRICE_ID=price_xxxxx
STRIPE_PERSONAL_ANNUAL_PRICE_ID=price_xxxxx
STRIPE_CREDITS_20_PRICE_ID=price_xxxxx
STRIPE_CREDITS_50_PRICE_ID=price_xxxxx

# Resend
RESEND_API_KEY=your-resend-api-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
